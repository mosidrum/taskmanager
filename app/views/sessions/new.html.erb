<% content_for :left_heading do %>
  <h2>Welcome back! 👋</h2>
  <p>Log in to your account and continue organizing your tasks and projects.</p>
<% end %>

<h1 class="auth-title">Log in to your account</h1>
<p class="auth-sub">Enter your details below to continue</p>

<% if flash[:alert] %>
  <div class="errors" style="margin-bottom: 20px;">
    <ul><li><%= flash[:alert] %></li></ul>
  </div>
<% end %>

<%= form_with url: login_path, method: :post do |f| %>
  <div class="auth-field">
    <label for="email">Email address</label>
    <div class="auth-input-wrap">
      <span class="ii-l">✉</span>
      <%= f.email_field :email, id: "email", placeholder: "Enter your email", name: "email" %>
    </div>
  </div>

  <div class="auth-field">
    <div class="auth-field-hdr">
      <label for="password">Password</label>
      <a href="#" class="forgot">Forgot password?</a>
    </div>
    <div class="auth-input-wrap">
      <span class="ii-l">🔒</span>
      <%= f.password_field :password, id: "password", placeholder: "Enter your password", name: "password" %>
      <span class="ii-r" onclick="togglePw(this)" style="cursor:pointer">👁</span>
    </div>
  </div>

  <div class="auth-remember">
    <input type="checkbox" id="remember_me" name="remember_me">
    <label for="remember_me">Remember me</label>
  </div>

  <%= f.submit "Log in", class: "btn-auth" %>
<% end %>

<div class="auth-divider"><span>or continue with</span></div>

<button class="social-btn">
  <span style="font-size:16px;font-weight:900;color:#4285F4;">G</span>
  Continue with Google
</button>

<button class="social-btn">
  <span class="ms-squares">
    <span style="background:#f25022;"></span>
    <span style="background:#00a4ef;"></span>
    <span style="background:#7fba00;"></span>
    <span style="background:#ffb900;"></span>
  </span>
  Continue with Microsoft
</button>

<button class="social-btn">
  <span style="font-size:16px;">🍎</span>
  Continue with Apple
</button>

<div class="auth-switch">
  Don't have an account? <%= link_to "Sign up", sign_up_path %>
</div>
