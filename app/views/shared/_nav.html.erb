<nav class="top-nav">
  <%= link_to root_path, class: "nav-brand" do %>
    <span class="nav-logo-box">✓</span>
    Taskmanager
  <% end %>

  <div class="nav-links">
    <%= link_to "Features", "#features" %>
    <%= link_to "How it works", "#how-it-works" %>
    <%= link_to "Tasks", tasks_path %>
    <%= link_to "About", about_path %>
  </div>

  <div class="nav-right">
    <% if current_user %>
      <%= link_to "Dashboard", dashboard_root_path, class: "nav-login" %>
      <%= button_to "Log out", logout_path, method: :delete, class: "btn-signup" %>
    <% else %>
      <%= link_to "Log in", login_path, class: "nav-login" %>
      <%= link_to "Get started free", sign_up_path, class: "btn-signup" %>
    <% end %>
  </div>

  <button class="hamburger" id="nav-hamburger" aria-label="Open menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div class="mobile-nav" id="mobile-nav">
  <%= link_to "Features", "#features" %>
  <%= link_to "How it works", "#how-it-works" %>
  <%= link_to "Tasks", tasks_path %>
  <%= link_to "About", about_path %>
  <div class="mobile-divider"></div>
  <% if current_user %>
    <%= link_to "Dashboard", dashboard_root_path %>
    <%= button_to "Log out", logout_path, method: :delete, class: "mobile-cta" %>
  <% else %>
    <%= link_to "Log in", login_path %>
    <%= link_to "Get started free", sign_up_path, class: "mobile-cta" %>
  <% end %>
</div>

<script>
  (function() {
    function initNav() {
      var btn = document.getElementById('nav-hamburger');
      var menu = document.getElementById('mobile-nav');
      if (!btn || !menu || btn._initialized) return;
      btn._initialized = true;
      btn.addEventListener('click', function() {
        btn.classList.toggle('open');
        menu.classList.toggle('open');
      });
      menu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          btn.classList.remove('open');
          menu.classList.remove('open');
        });
      });
    }
    document.addEventListener('DOMContentLoaded', initNav);
    document.addEventListener('turbo:load', initNav);
  })();
</script>
