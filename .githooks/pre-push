#!/bin/sh

export PATH="$HOME/.rbenv/bin:$PATH"
eval "$(rbenv init -)"

while read local_ref local_sha remote_ref remote_sha; do
  echo "$remote_ref" | grep -q "refs/heads/main" || continue

  echo "→ Running RuboCop before push to main..."
  bundle exec rubocop --no-color

  if [ $? -ne 0 ]; then
    echo ""
    echo "  RuboCop failed. Fix all offenses before pushing to main."
    echo ""
    exit 1
  fi
done
